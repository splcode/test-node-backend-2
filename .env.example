# Copy to .env for local development: cp .env.example .env

# Port Express listens on (defaults to 3000)
PORT=3000

# Postgres connection — REQUIRED. The app reads samples from the database and
# runs migrations automatically on startup.
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgres://app:app@localhost:5433/app

# --- Auth / OIDC (dev) -------------------------------------------------------
# Keycloak runs in docker-compose at :8082. Express runs on the host, so both
# the server (token calls) and the browser (redirects) reach the issuer at the
# same localhost URL — no docker-network hostname split to worry about in dev.
# Realm + clients are created by: npm run seed:keycloak -w backend
OIDC_ISSUER=http://localhost:8082/realms/app
OIDC_CLIENT_ID=web-bff
OIDC_CLIENT_SECRET=dev-secret-change-me
# Dev default is the Vite origin (:5173, HMR); Vite proxies /api + /auth to
# Express, so the browser stays on one origin. If you instead serve the built
# SPA from Express (single origin), use http://localhost:3000/auth/callback.
# Both are registered on the web-bff client by the seeder.
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

# Audience the resource server (jose) requires on incoming bearer tokens. The
# seed adds a Keycloak audience mapper that stamps this onto access tokens.
OIDC_AUDIENCE=app-api

# Signs the session cookie. Any long random string for dev; rotate for prod.
SESSION_SECRET=dev-session-secret-change-me

# Machine-to-machine client for exercising the client-credentials API leg.
# Not needed by the server; handy for curl/testing API clients in dev.
API_M2M_CLIENT_ID=api-m2m
API_M2M_CLIENT_SECRET=dev-m2m-secret

# Override to match your hosted Phase Two version in prod (see docker-compose).
KEYCLOAK_VERSION=26.6.2
